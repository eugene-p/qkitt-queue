{
  "name": "@qkitt/queue",
  "version": "0.1.1",
  "type": "module",
  "description": "A small, typed FIFO queue toolkit for TypeScript",
  "license": "ISC",
  "author": "eugene-p",
  "keywords": [
    "queue",
    "fifo",
    "worker",
    "retry",
    "pipeline",
    "router",
    "topic",
    "persist",
    "typescript",
    "esm"
  ],
  "homepage": "https://github.com/eugene-p/qkitt-queue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugene-p/qkitt-queue.git"
  },
  "bugs": {
    "url": "https://github.com/eugene-p/qkitt-queue/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "default": "./dist/events/index.js"
    },
    "./persist": {
      "types": "./dist/persist/index.d.ts",
      "import": "./dist/persist/index.js",
      "default": "./dist/persist/index.js"
    },
    "./queue": {
      "types": "./dist/queue/index.d.ts",
      "import": "./dist/queue/index.js",
      "default": "./dist/queue/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js",
      "default": "./dist/router/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js",
      "default": "./dist/worker/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup && tsc -p tsconfig.build.json",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run typecheck && npm test && npm run build && npm run pack:check",
    "prepublishOnly": "npm run release:check"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
