{
  "name": "@qkitt/queue",
  "version": "0.6.2",
  "type": "module",
  "description": "Fast, composable in-process queues for TypeScript — zero runtime dependencies",
  "license": "ISC",
  "author": "eugene-p",
  "keywords": [
    "queue",
    "fifo",
    "worker",
    "retry",
    "pipeline",
    "router",
    "topic",
    "persist",
    "typescript",
    "esm",
    "job queue",
    "task queue",
    "concurrency",
    "in-process",
    "zero-dependency",
    "backpressure",
    "event emitter"
  ],
  "homepage": "https://github.com/eugene-p/qkitt-queue#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugene-p/qkitt-queue.git",
    "directory": "packages/queue"
  },
  "bugs": {
    "url": "https://github.com/eugene-p/qkitt-queue/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "default": "./dist/events/index.js"
    },
    "./persist": {
      "types": "./dist/persist/index.d.ts",
      "import": "./dist/persist/index.js",
      "default": "./dist/persist/index.js"
    },
    "./persist/stores": {
      "types": "./dist/persist/stores/index.d.ts",
      "import": "./dist/persist/stores/index.js",
      "default": "./dist/persist/stores/index.js"
    },
    "./persist/stores/memory": {
      "types": "./dist/persist/stores/memory.d.ts",
      "import": "./dist/persist/stores/memory.js",
      "default": "./dist/persist/stores/memory.js"
    },
    "./persist/stores/web-storage": {
      "types": "./dist/persist/stores/web-storage.d.ts",
      "import": "./dist/persist/stores/web-storage.js",
      "default": "./dist/persist/stores/web-storage.js"
    },

    "./queue": {
      "types": "./dist/queue/index.d.ts",
      "import": "./dist/queue/index.js",
      "default": "./dist/queue/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js",
      "default": "./dist/router/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js",
      "default": "./dist/worker/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/prune-dts.mjs",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run typecheck && npm test && npm run build && npm run pack:check"
  }
}
